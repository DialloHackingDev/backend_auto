# ═══════════════════════════════════════════════════════
# AutoConnect Backend — Configuration des variables d'env
# ═══════════════════════════════════════════════════════
# Copier ce fichier en .env et remplir les valeurs réelles
# Ne JAMAIS commiter le fichier .env dans git !
# ═══════════════════════════════════════════════════════

# ─────────────────────────────────
# Application
# ─────────────────────────────────
PORT=3000
NODE_ENV=development
APP_NAME=AutoConnect API
API_VERSION=v1

# ─────────────────────────────────
# Base de données — Prisma
# ─────────────────────────────────
# Développement local (Docker)
DATABASE_URL="postgresql://postgres:autoconnect_secret@localhost:5432/autoconnect?schema=public"

# Production (Neon)
# DATABASE_URL="postgresql://user:password@ep-xxxx.neon.tech/autoconnect?sslmode=require"

# Variables Docker PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=autoconnect_secret
POSTGRES_DB=autoconnect

# ─────────────────────────────────
# Redis — Cache & OTP
# ─────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret

# ─────────────────────────────────
# JWT — Authentification
# ─────────────────────────────────
# IMPORTANT: Changer ces valeurs en production !
JWT_SECRET=autoconnect_jwt_super_secret_key_change_in_prod
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=autoconnect_refresh_super_secret_key_change_in_prod
JWT_REFRESH_EXPIRES_IN=7d

# ─────────────────────────────────
# CORS — Origines autorisées
# ─────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080

# ─────────────────────────────────
# Rate Limiting
# ─────────────────────────────────
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# ─────────────────────────────────
# OTP — Codes de vérification
# ─────────────────────────────────
OTP_TTL_SECONDS=300
OTP_LENGTH=6

# ─────────────────────────────────
# Wallet — Commission plateforme
# ─────────────────────────────────
PLATFORM_COMMISSION_RATE=0.10

# ─────────────────────────────────
# Paiement Mobile Money (à configurer plus tard)
# ─────────────────────────────────
ORANGE_MONEY_API_URL=https://api.orange-money.com
ORANGE_MONEY_API_KEY=YOUR_ORANGE_MONEY_API_KEY
MTN_MONEY_API_URL=https://api.mtn-money.com
MTN_MONEY_API_KEY=YOUR_MTN_MONEY_API_KEY

# ─────────────────────────────────
# Logging
# ─────────────────────────────────
LOG_LEVEL=debug
